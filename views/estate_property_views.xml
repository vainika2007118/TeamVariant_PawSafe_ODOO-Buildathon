<odoo>
    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

<record id="estate_property_view_list" model="ir.ui.view">
    <field name="name">estate.property.list</field>
    <field name="model">estate.property</field>
    <field name="arch" type="xml">
        <tree decoration-muted="state == 'sold'">
            <field name="name" />
            <field name="state" invisible="1" />
        </tree>
    </field>
</record>

    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="sell_property" type="object" string="Sell" invisible="state in ('sold', 'cancelled')" />
                        <button name="cancel_property" type="object" string="Cancel" invisible="state in ('sold', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="new,offer_received,offer_accepted,sold" />
                    </header>
                    <group>
                        <field name="name" />
                        <field name="description" />
                        <field name="tag_ids" widget="many2many_tags" />
                        <field name="expected_price" />
                        <field name="selling_price" />
                        <field name="bedrooms" />
                        <field name="living_area" />
                        <field name="has_garden" />
                        <field name="garden_area" invisible="not has_garden"/>
                        <field name="total_area" />
                        <field name="property_type_id" />
                        <field name="best_price" />
                        <field name="state" />
                    </group>
                    <group>
                        <notebook>
                            <page string="Other Info">
                                <group>
                                    <field name="salesperson_id" />
                                    <field name="buyer_id" />
                                </group>
                            </page>
                            <page string="Offers">
                                <field name="offer_ids" readonly="state in ('offer_accepted', 'sold', 'cancelled')"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_view_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban default_group_by="property_type_id" records_draggable="False">
                <templates>
                    <t t-name="card">
                        <field name="name" string="Name" />
                        <field name="expected_price" string="Expected Price" />
                        <field name="tag_ids" widget="many2many_tags"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>